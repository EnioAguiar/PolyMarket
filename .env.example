# Polymarket Bot - Environment Variables
# Copy to .env and fill in values

# === Research APIs ===
# NewsData.io - Real-time news (free tier: 500/day)
# Sign up at: https://newsdata.io
NEWSDATA_API_KEY=

# X (Twitter) API v2 - Social media research (free tier)
# Sign up at: https://developer.twitter.com
# Get Bearer Token from: https://developer.twitter.com/en/apps
TWITTER_BEARER_TOKEN=

# === AI ===
MINIMAX_API_KEY=

# === Wallet (Polymarket trading) ===
PRIVATE_KEY=
# Deposit wallet address - get from polymarket.com/settings or via POST /deposit API
DEPOSIT_WALLET_ADDRESS=

# === Telegram Bot ===
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
