{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "idleTimeoutSeconds": 300
  },
  "healthCheck": {
    "path": "/health",
    "intervalSeconds": 30,
    "timeoutSeconds": 5,
    "startupSeconds": 30
  },
  "volumes": [
    {
      "mountPath": "/data",
      "name": "polymarket-data"
    }
  ]
}
