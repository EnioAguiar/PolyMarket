{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "python": "3.13"
  },
  "steps": {
    "install": {
      "commands": ["npm ci"]
    },
    "build": {
      "commands": ["npm run build"]
    }
  },
  "deploy": {
    "command": "/root/.local/bin/mise exec -- python3 -m pip install -r requirements.txt && npm start"
  }
}